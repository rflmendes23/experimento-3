// Collect numeric table data
const LABELS={r:'r (mm)',h:'h (mm)',sqrtH:'√h (m^½)',v:'v (m/s)'};
function getPlotData(){
  const c=getConsts();
  return S.rows.map(row=>{
    const h=parseFloat(row.h),r=parseFloat(row.r);
    const {sqrtH,v}=(row.h===''||isNaN(h))?{sqrtH:null,v:null}:calcRow(h,c.K,c.Q,c.D);
    return {ensaio:row.ensaio,pos:row.pos,
      r:(!row.r||isNaN(r))?null:r,
      h:(!row.h||isNaN(h))?null:h,
      sqrtH,v};
  });
}

function buildChartCfg(data,xk,yk,title,units){
  const pts=data.filter(d=>d[xk]!==null&&d[yk]!==null);
  const xu=LABELS[xk]+(units?` [${units}]`:'');
  const yu=LABELS[yk]+(units?` [${units}]`:'');
  return {
    type:'scatter',
    data:{datasets:[{
      label:title,
      data:pts.map(d=>({x:d[xk],y:d[yk]})),
      borderColor:'#00c8ff',backgroundColor:'rgba(0,200,255,.18)',
      pointRadius:6,pointHoverRadius:9,showLine:true,tension:.35,borderWidth:2,
    }]},
    options:{
      responsive:true,maintainAspectRatio:true,
      plugins:{
        title:{display:!!title,text:title,color:'#e8f4fc',font:{size:13,family:"'Syne',sans-serif"}},
        legend:{display:false},
      },
      scales:{
        x:{title:{display:true,text:xu,color:'#4a6a7f'},ticks:{color:'#4a6a7f'},grid:{color:'rgba(30,58,82,.5)'}},
        y:{title:{display:true,text:yu,color:'#4a6a7f'},ticks:{color:'#4a6a7f'},grid:{color:'rgba(30,58,82,.5)'}},
      }
    }
  };
}

function updatePreviewChart(){
  const xk=document.getElementById('g-x')?.value||'r';
  const yk=document.getElementById('g-y')?.value||'v';
  const title=document.getElementById('g-title')?.value||'';
  const units=document.getElementById('g-units')?.value||'';
  S.gX=xk;S.gY=yk;S.gTitle=title;S.gUnits=units;
  const data=getPlotData();
  const pts=data.filter(d=>d[xk]!==null&&d[yk]!==null);
  const emptyMsg=document.getElementById('chart-empty-msg');
  const cv=document.getElementById('cv-prev');
  if(pts.length<2){emptyMsg.style.display='block';cv.style.display='none';return;}
  emptyMsg.style.display='none';cv.style.display='block';
  if(chartPrev){chartPrev.destroy();chartPrev=null;}
  chartPrev=new Chart(cv.getContext('2d'),buildChartCfg(data,xk,yk,title,units));
}

