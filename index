// ============================================================
// EXPERIMENT TABLE
// ============================================================
function getConsts(){
  const K   = parseFloat(document.getElementById('c-K')?.value)||4.427189;
  const A_t = parseFloat(document.getElementById('c-At')?.value)||0.546;
  const t   = parseFloat(document.getElementById('c-t')?.value)||19.56;
  const dh  = parseFloat(document.getElementById('c-dh')?.value)||0.1;
  const D   = parseFloat(document.getElementById('c-D')?.value)||41;
  const Q   = (dh * A_t) / t;   // Q = (Δh * A_tanque) / t
  // Update displayed Q
  const qEl = document.getElementById('c-Q');
  if(qEl) qEl.value = Q.toFixed(6);
  return {Q, K, A_t, t, dh, D};
}

function calcRow(h,K,Q,D){
  const A_pipe=Math.PI*Math.pow(D/2000,2);
  const fsq=document.getElementById('f-sqrth')?.value||'Math.sqrt(h)';
  const fv= document.getElementById('f-v')?.value||'K * sqrtH';
  let sqrtH=NaN,v=NaN;
  try{ sqrtH=new Function('h','K','Q','D_tubo','A_pipe','return '+fsq)(h,K,Q,D,A_pipe); }catch(e){}
  try{ v=new Function('h','sqrtH','K','Q','D_tubo','A_pipe','return '+fv)(h,sqrtH,K,Q,D,A_pipe); }catch(e){}
  return {sqrtH,v};
}

function vmIntegral(){
  const c=getConsts();
  const R=c.D/2;
  const valid=S.rows.filter(r=>r.r!==''&&r.h!=='');
  if(valid.length<2)return NaN;
  // Group by |r|, average symmetric velocities
  const map={};
  valid.forEach(row=>{
    const rabs=Math.abs(parseFloat(row.r));
    const {v}=calcRow(parseFloat(row.h),c.K,c.Q,c.D);
    if(!isNaN(v)){if(!map[rabs])map[rabs]=[];map[rabs].push(v);}
  });
  const rs=Object.keys(map).map(Number).sort((a,b)=>a-b);
  const vs=rs.map(r=>map[r].reduce((a,b)=>a+b,0)/map[r].length);
  let integral=0;
  for(let i=0;i<rs.length-1;i++){
    const r1=rs[i],r2=rs[i+1],f1=vs[i]*r1,f2=vs[i+1]*r2;
    integral+=(r2-r1)*(f1+f2)/2;
  }
  return R>0?(2/(R*R))*integral:NaN;
}

function recalc(){
  const tbody=document.getElementById('exp-tbody');
  if(!tbody)return;
  const c=getConsts();
  tbody.querySelectorAll('tr').forEach((tr,i)=>{
    const ri=tr.querySelector('.ri');
    const hi=tr.querySelector('.hi');
    if(ri) S.rows[i].r=ri.value;
    if(hi) S.rows[i].h=hi.value;
    const h=parseFloat(S.rows[i].h);
    const {sqrtH,v}=(S.rows[i].h===''||isNaN(h))?{sqrtH:NaN,v:NaN}:calcRow(h,c.K,c.Q,c.D);
    tr.querySelector('.sqc').textContent=isNaN(sqrtH)?'—':sqrtH.toFixed(6);
    tr.querySelector('.vc').textContent=isNaN(v)?'—':v.toFixed(6);
  });
  // Vm calculada = (49/60) * v do ensaio 4 (posição 'c', index 3)
  const row4h = parseFloat(S.rows[3].h);
  let vm1 = NaN;
  if(!isNaN(row4h) && S.rows[3].h !== ''){
    const {v: v4} = calcRow(row4h, c.K, c.Q, c.D);
    if(!isNaN(v4)) vm1 = (49/60) * v4;
  }
  document.getElementById('vm-calc').textContent = isNaN(vm1) ? '—' : vm1.toFixed(6)+' m/s';

  // Vm vazão = (Q * 4) / (π * D_tubo²)  [D in meters]
  const {Q, D} = c;
  const vm2 = (Q * 4) / (Math.PI * Math.pow(D * 1e-3, 2));  // D em mm → (D×10⁻³) em metros
  document.getElementById('vm-vazao').textContent = isNaN(vm2) ? '—' : vm2.toFixed(6)+' m/s';
  // update preview chart if open
  if(document.getElementById('sw-graph')?.checked) updatePreviewChart();
}

