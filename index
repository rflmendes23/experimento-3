    <div class="vm-display">
      V<sub>m</sub>(calculada): <span>${document.getElementById('vm-calc').textContent}</span>
      &nbsp;&nbsp;V<sub>m</sub>(vazão): <span>${document.getElementById('vm-vazao').textContent}</span>
    </div>`;

  // Conclusion
  const cc=document.getElementById('rev-conc-card');
  const rc=document.getElementById('rev-conc');
  if(S.inclConc&&S.conclusions.length){
    cc.style.display='block';
    rc.innerHTML=S.conclusions.map(c=>`<p style="margin-bottom:.7rem;line-height:1.7;font-size:.88rem">${c}</p>`).join('');
  } else cc.style.display='none';

  // Graph
  const gc=document.getElementById('rev-graph-card');
  if(S.inclGraph){
    gc.style.display='block';
    setTimeout(()=>{
      if(chartRev){chartRev.destroy();chartRev=null;}
      const cv=document.getElementById('cv-review');
      const data=getPlotData().filter(d=>d[S.gX]!==null&&d[S.gY]!==null);
      if(data.length>=2) chartRev=new Chart(cv.getContext('2d'),buildChartCfg(getPlotData(),S.gX,S.gY,S.gTitle,S.gUnits));
    },100);
  } else gc.style.display='none';
}

// ============================================================
// PDF DOWNLOAD
// ============================================================
async function downloadPDF(){
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
  const W=210,M=18;
  let y=M;

  const nl=(n=5)=>{y+=n;};
  const line=()=>{doc.setDrawColor(180,200,215);doc.line(M,y,W-M,y);nl(4);};

  // --- Header ---
  doc.setFillColor(7,13,20);doc.rect(0,0,W,42,'F');
  doc.setFontSize(8);doc.setTextColor(74,106,127);
  doc.text('MECÂNICA DOS FLUIDOS',W/2,15,{align:'center'});
  doc.setFontSize(18);doc.setTextColor(0,200,255);
  doc.text('Experimento 3',W/2,26,{align:'center'});
  y=46;doc.setTextColor(20,20,20);

  // --- Members ---
  doc.setFontSize(11);doc.setFont(undefined,'bold');doc.setTextColor(0,100,140);
  doc.text('Integrantes do Grupo',M,y);doc.setFont(undefined,'normal');nl(5);line();
  S.members.forEach(m=>{
    doc.setFontSize(8.5);doc.setTextColor(30,30,30);doc.text(m.name,M,y);
    doc.setTextColor(0,100,140);doc.text('RA: '+m.ra,W-M,y,{align:'right'});
    doc.setTextColor(30,30,30);nl(5.5);
  });
  nl(3);

  // --- Table ---
  if(y>230){doc.addPage();y=M;}
  doc.setFont(undefined,'bold');doc.setFontSize(11);doc.setTextColor(0,100,140);
  doc.text('Dados do Experimento',M,y);doc.setFont(undefined,'normal');nl(5);line();

  const cols=[{lbl:'Ensaio',w:16},{lbl:'Posição',w:22},{lbl:'r (mm)',w:24},{lbl:'h (mm)',w:24},{lbl:'√h (m^½)',w:30},{lbl:'v (m/s)',w:30}];
  const tw=cols.reduce((a,c)=>a+c.w,0);

  // table header
  doc.setFillColor(7,13,20);doc.rect(M,y,tw,8,'F');
  doc.setFontSize(7);doc.setTextColor(0,200,255);
  let cx=M;
  cols.forEach(c=>{doc.text(c.lbl,cx+c.w/2,y+5.3,{align:'center'});cx+=c.w;});
  nl(9);

  const pd=getPlotData();
  pd.forEach((d,idx)=>{
    if(y>268){doc.addPage();y=M;}
    if(idx%2===0){doc.setFillColor(238,247,255);doc.rect(M,y-1,tw,7,'F');}
    doc.setFontSize(7.5);doc.setTextColor(20,20,20);
    cx=M;
    const vs=[d.ensaio,d.pos,d.r??'—',d.h??'—',d.sqrtH!==null?d.sqrtH.toFixed(4):'—',d.v!==null?d.v.toFixed(4):'—'];
    vs.forEach((v,i)=>{doc.text(String(v),cx+cols[i].w/2,y+4,{align:'center'});cx+=cols[i].w;});
    nl(7);
  });
  nl(3);
  doc.setFontSize(8.5);doc.setTextColor(30,30,30);
  doc.text('Vm(calculada) = '+document.getElementById('vm-calc').textContent,M,y);nl(5.5);
  doc.text('Vm(vazão) = '+document.getElementById('vm-vazao').textContent,M,y);nl(8);

  // --- Constants ---
  if(y>240){doc.addPage();y=M;}
  doc.setFont(undefined,'bold');doc.setFontSize(10);doc.setTextColor(0,100,140);
  doc.text('Constantes',M,y);doc.setFont(undefined,'normal');nl(5);line();
  const c2=getConsts();
  const cpairs=[['Q',c2.Q+' m³/s'],['K',c2.K+' (constante)'],['A_tanque',c2.A_t+' m²'],
    ['t',c2.t+' s'],['Δh',c2.dh+' m'],['D_tubo',c2.D+' mm']];
  doc.setFontSize(8);doc.setTextColor(30,30,30);
  cpairs.forEach(([k,v])=>{doc.text(k+': '+v,M,y);nl(5.2);});
  nl(5);

  // --- Conclusion ---
  if(S.inclConc&&S.conclusions.length){
    if(y>240){doc.addPage();y=M;}
    doc.setFont(undefined,'bold');doc.setFontSize(11);doc.setTextColor(0,100,140);
    doc.text('Conclusão',M,y);doc.setFont(undefined,'normal');nl(5);line();
    doc.setFontSize(8.5);doc.setTextColor(30,30,30);
    S.conclusions.forEach(cl=>{
      const lns=doc.splitTextToSize(cl,W-2*M);
      lns.forEach(ln=>{if(y>272){doc.addPage();y=M;}doc.text(ln,M,y);nl(5.2);});
      nl(2);
    });
  }

  // --- Graph ---
  if(S.inclGraph){
    doc.addPage();y=M;
    doc.setFont(undefined,'bold');doc.setFontSize(11);doc.setTextColor(0,100,140);
    doc.text('Gráfico: '+S.gTitle,M,y);doc.setFont(undefined,'normal');nl(5);line();
    try{
      // Render chart onto an offscreen canvas with white background for clean PDF export
      const offCanvas = document.createElement('canvas');
      offCanvas.width = 900; offCanvas.height = 480;
      const offCtx = offCanvas.getContext('2d');
      offCtx.fillStyle = '#ffffff';
      offCtx.fillRect(0,0,offCanvas.width,offCanvas.height);
      const plotData = getPlotData();
      const xu = (LABELS[S.gX]||S.gX)+(S.gUnits?' ['+S.gUnits+']':'');
      const yu = (LABELS[S.gY]||S.gY)+(S.gUnits?' ['+S.gUnits+']':'');
      const pts = plotData.filter(d=>d[S.gX]!==null&&d[S.gY]!==null);
      const tempChart = new Chart(offCtx,{
        type:'scatter',
        data:{datasets:[{
          label:S.gTitle,
          data:pts.map(d=>({x:d[S.gX],y:d[S.gY]})),
          borderColor:'#0050a0',backgroundColor:'rgba(0,80,160,0.15)',
          pointRadius:7,pointHoverRadius:9,showLine:true,tension:.35,borderWidth:2.5,
        }]},
        options:{
          animation:false,responsive:false,
          plugins:{
            title:{display:!!S.gTitle,text:S.gTitle,color:'#111',font:{size:18,weight:'bold',family:'Arial'}},
            legend:{display:false},
          },
          scales:{
            x:{title:{display:true,text:xu,color:'#333',font:{size:14,family:'Arial'}},
               ticks:{color:'#333',font:{size:12}},grid:{color:'rgba(0,0,0,.12)'},
               border:{color:'#999'}},
            y:{title:{display:true,text:yu,color:'#333',font:{size:14,family:'Arial'}},
               ticks:{color:'#333',font:{size:12}},grid:{color:'rgba(0,0,0,.12)'},
               border:{color:'#999'}},
          }
        }
      });
      const imgData = offCanvas.toDataURL('image/png');
      tempChart.destroy();
      const maxW=W-2*M, maxH=120;
      doc.addImage(imgData,'PNG',M,y,maxW,maxH);
      y+=maxH+5;
    }catch(e){doc.setFontSize(8);doc.setTextColor(80,80,80);doc.text('[Gráfico não disponível: '+e.message+']',M,y);}
  }

  // --- Footer ---
  const np=doc.internal.getNumberOfPages();
  for(let i=1;i<=np;i++){
    doc.setPage(i);doc.setFontSize(6.5);doc.setTextColor(74,106,127);
    doc.text('Experimento 3 — Mecânica dos Fluidos',W/2,292,{align:'center'});
    doc.text(String(i)+'/'+np,M,292);
  }

  doc.save('experimento3_mecflu.pdf');
  notify('✓ PDF gerado com sucesso!');
}

// ============================================================
// EXCEL DOWNLOAD
// ============================================================
function downloadExcel(){
  const wb=XLSX.utils.book_new();
  const pd=getPlotData();
  const c=getConsts();

  // Sheet 1: Members
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['Nome','RA'],
    ...S.members.map(m=>[m.name,m.ra])
  ]),'Integrantes');

  // Sheet 2: Experiment data
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['Experimento 3 — Mecânica dos Fluidos'],[''],
    ['Ensaio','Posição','r (mm)','h (mm)','√h (m^½)','v (m/s)'],
    ...pd.map(d=>[d.ensaio,d.pos,d.r??'',d.h??'',
      d.sqrtH!==null?parseFloat(d.sqrtH.toFixed(6)):'',
      d.v!==null?parseFloat(d.v.toFixed(6)):'']),
    [''],
    ['Vm calculada',document.getElementById('vm-calc').textContent],
    ['Vm vazão',document.getElementById('vm-vazao').textContent],
    [''],
    ['Constantes'],
    ['Q (m³/s)',c.Q],['K',c.K],['A_tanque (m²)',c.A_t],
    ['t (s)',c.t],['Δh (m)',c.dh],['D_tubo (mm)',c.D],
  ]),'Experimento');

  // Sheet 3: Conclusion
  if(S.inclConc&&S.conclusions.length){
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
      ['Conclusão'],[''],
      ...S.conclusions.map((cl,i)=>[i+1,cl])
    ]),'Conclusão');
  }

  XLSX.writeFile(wb,'experimento3_mecflu.xlsx');
  notify('✓ Excel gerado com sucesso!');
}

// ============================================================
// UTILS
// ============================================================
let notifTimer=null;
function notify(msg){
  const el=document.getElementById('notif');
  el.textContent=msg;el.style.display='block';
  el.style.animation='none';void el.offsetWidth;
  el.style.animation='popIn .3s ease forwards';
  clearTimeout(notifTimer);
  notifTimer=setTimeout(()=>el.style.display='none',2600);
}
</script>
